            border-radius: 12px;
            padding: 14px;
            margin-bottom: 16px;
            font-size: 13px;
            color: var(--text-primary);
            line-height: 1.5;
        }

        .pattern-color-warning strong {
            color: var(--orange);
        }

        /* Color Search */
        .color-search-section {
            margin-bottom: 16px;
        }

        .color-search-input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--blush);
            border-radius: 12px;
            font-size: 14px;
            outline: none;
            transition: all 0.3s ease;
            background: var(--bg-primary);
            color: var(--text-primary);
        }

        [data-theme="dark"] .color-search-input {
            border-color: rgba(234, 142, 160, 0.3);
        }

        .color-search-input:focus {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(234, 142, 160, 0.2);
        }

        .color-search-input::placeholder {
            color: var(--text-secondary);
