        .upload-text {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .upload-hint {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .uploaded-image-preview {
            width: 100%;
            max-height: 300px;
            border-radius: 12px;
            object-fit: contain;
            margin-bottom: 16px;
        }

        .change-image-btn {
            padding: 12px 24px;
            background: rgba(234, 142, 160, 0.1);
            color: var(--coral);
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            appearance: none;
            -webkit-appearance: none;
