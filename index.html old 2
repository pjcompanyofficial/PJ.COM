        .change-image-btn:hover {
            background: var(--coral);
            color: white;
        }

        .upload-file-btn {
            margin-top: 12px;
            padding: 12px 24px;
            background: linear-gradient(135deg, var(--orange) 0%, var(--coral) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.1s ease, box-shadow 0.1s ease;
            box-shadow: 0 4px 0 var(--orange-dark);
            appearance: none;
            -webkit-appearance: none;
