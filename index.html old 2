            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
            display: block;
        }

        .count-price {
            font-size: 12px;
            color: var(--coral);
            margin-top: 4px;
            display: block;
        }

        /* Color Selection */
        .color-selection-section {
            background: var(--bg-secondary);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 24px;
            border: 2px solid var(--border-color);
