<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>PJ Store | Professional Flutes</title>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Inter:wght@300;400;500;600&amp;display=swap" rel="stylesheet"/>
<style>
*{-webkit-tap-highlight-color: transparent; outline:none;}
        :root {
            --coral: #ea8ea0;
            --coral-dark: #d86a7d;
            --coral-light: #f4b3be;
            --orange: #f39a52;
            --orange-dark: #e07c33;
            --orange-light: #f8c58f;
            --blush: #f5d5d5;
            --blush-light: #fae8e8;
            --cream: #faf7f4;
            --rose: #d6828c;
            --foreground: #2d2a26;
            
            /* Light mode defaults */
            --bg-primary: #faf7f4;
            --bg-secondary: #ffffff;
            --text-primary: #2d2a26;
            --text-secondary: rgba(45, 42, 38, 0.7);
            --border-color: rgba(234, 142, 160, 0.2);
            --card-shadow: rgba(0,0,0,0.05);
        }

        [data-theme="dark"] {
            --bg-primary: #121212;
            --bg-secondary: #1e1e1e;
            --text-primary: #f5d5d5;
            --text-secondary: rgba(245, 213, 213, 0.7);
            --border-color: rgba(234, 142, 160, 0.3);
            --card-shadow: rgba(0,0,0,0.3);
            --cream: #1a1a1a;
            --foreground: #f5d5d5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }


        /* Remove Chrome click/focus blue highlight */
        button, a, input, textarea, select, [role=button] {
            -webkit-tap-highlight-color: transparent;
        }

        button:focus,
        a:focus,
        input:focus,
        textarea:focus,
        select:focus,
        [role=button]:focus {
            outline: none;
        }

        button:focus:not(:focus-visible),
        a:focus:not(:focus-visible),
        input:focus:not(:focus-visible),
        textarea:focus:not(:focus-visible),
        select:focus:not(:focus-visible),
        [role=button]:focus:not(:focus-visible) {
            outline: none;
            box-shadow: none;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            position: relative;
            transition: background 0.5s ease, color 0.5s ease;
        }

        .background-watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            width: 320px;
            height: 320px;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            background: rgba(234, 142, 160, 0.03);
            border: 1px solid rgba(234, 142, 160, 0.06);
            box-shadow: 0 20px 70px rgba(0,0,0,0.02);
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
            opacity: 0.5;
        }

        [data-theme="dark"] .background-watermark {
            background: rgba(234, 142, 160, 0.05);
            opacity: 0.3;
        }

        .background-watermark img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            display: block;
        }

        .page-content {
            position: relative;
            z-index: 1;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Great Vibes', cursive;
            font-weight: 400;
        }

        /* Navigation */
        .nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            padding: 12px 20px;
            z-index: 1000;
            box-shadow: 0 4px 20px rgba(234, 142, 160, 0.3);
        }

        .nav-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid white;
            object-fit: cover;
        }

        .logo span {
            color: white;
            font-weight: 700;
            font-size: 16px;
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 24px;
        }

        .nav-links a {
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: white;
        }

        .nav-icons {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .nav-icons button, .nav-icons a {
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            border-radius: 50%;
            transition: background 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-icons button:hover, .nav-icons a:hover {
            background: rgba(255,255,255,0.1);
        }

        .cart-btn {
            position: relative;
        }

        .cart-count {
            position: absolute;
            top: -4px;
            right: -4px;
            background: white;
            color: var(--coral);
            font-size: 11px;
            font-weight: 700;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--coral);
        }

        /* Hero Section */
        .hero {
            padding-top: 100px;
            padding-bottom: 30px;
            text-align: center;
        }

        .hero-title {
            font-size: 72px;
            color: var(--coral);
            margin-bottom: 20px;
            opacity: 0;
            transform: translateY(30px);
            animation: bloomIn 0.8s ease forwards;
        }

        .hero-slider {
            max-width: 700px;
            margin: 0 auto;
            border-radius: 24px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 10px 40px rgba(234, 142, 160, 0.2);
            transition: transform 0.4s, box-shadow 0.4s;
        }

        .hero-slider:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(234, 142, 160, 0.3);
        }

        .slider-container {
            aspect-ratio: 16/10;
            position: relative;
        }

        .slide {
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: opacity 1s ease;
        }

        .slide.active {
            opacity: 1;
        }

        .slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .slider-dots {
            position: absolute;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,0.5);
            border: none;
            cursor: pointer;
            transition: all 0.3s;
        }

        .dot.active {
            width: 24px;
            background: var(--coral);
        }

        .hero-subtitle {
            font-size: 36px;
            margin-top: 24px;
            color: var(--text-primary);
            opacity: 0;
            animation: bloomIn 0.8s ease 0.3s forwards;
        }

        /* Pincode Checker */
        .pincode-section {
            padding: 20px;
        }

        .pincode-box {
            max-width: 500px;
            margin: 0 auto;
            padding: 16px;
            background: rgba(234, 142, 160, 0.08);
            border: 1px solid rgba(234, 142, 160, 0.2);
            border-radius: 16px;
            opacity: 0;
            transform: translateY(30px);
        }

        [data-theme="dark"] .pincode-box {
            background: rgba(234, 142, 160, 0.1);
            border-color: rgba(234, 142, 160, 0.3);
        }

        .pincode-box.visible {
            animation: bloomIn 0.8s ease forwards;
        }

        .pincode-input-row {
            display: flex;
            gap: 12px;
        }

        .pincode-box input {
            flex: 1;
            padding: 14px 16px;
            border: 1px solid var(--blush);
            border-radius: 12px;
            font-size: 14px;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        [data-theme="dark"] .pincode-box input {
            border-color: rgba(234, 142, 160, 0.3);
            background: #2a2a2a;
        }

        .pincode-box input:focus {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(234, 142, 160, 0.2);
        }

        .pincode-box button {
            padding: 14px 24px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        .pincode-box button:hover {
            background: var(--orange-dark);
        }

        .pincode-result {
            text-align: center;
            font-size: 13px;
            margin-top: 12px;
            min-height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            color: var(--text-primary);
        }

        .pincode-result.success {
            color: #22c55e;
        }

        .pincode-result.error {
            color: var(--rose);
        }

        .detect-location {
            text-align: center;
            font-size: 12px;
            color: var(--coral);
            margin-top: 8px;
            cursor: pointer;
            text-decoration: underline;
        }

        .pincode-help {
            text-align: center;
            font-size: 12px;
            line-height: 1.5;
            color: var(--text-secondary);
            margin-top: 10px;
        }

        /* Video Section */
        .video-section {
            padding: 10px 20px 40px;
            text-align: center;
        }

        .video-title {
            font-size: 30px;
            color: var(--coral);
            margin-bottom: 16px;
        }

        .video-frame-wrap {
            max-width: 900px;
            margin: 0 auto;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 12px 36px rgba(234, 142, 160, 0.18);
            background: var(--bg-secondary);
            border: 1px solid rgba(234, 142, 160, 0.14);
        }

        .video-frame {
            width: 100%;
            aspect-ratio: 16 / 9;
            border: 0;
            display: block;
        }

        /* Products Grid */
        .products-section {
            padding: 40px 20px;
        }

        .products-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }

        .product-card {
            background: var(--bg-secondary);
            border-radius: 24px;
            padding: 20px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 20px var(--card-shadow);
            transition: transform 0.4s, box-shadow 0.4s, background 0.5s;
            opacity: 0;
            transform: translateY(30px);
        }

        .product-card.visible {
            animation: bloomIn 0.8s ease forwards;
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(234, 142, 160, 0.15);
        }

        .product-slider {
            position: relative;
            aspect-ratio: 1;
            border-radius: 16px;
            overflow: hidden;
            background: linear-gradient(to bottom, var(--cream), rgba(245, 213, 213, 0.3));
        }

        [data-theme="dark"] .product-slider {
            background: linear-gradient(to bottom, #2a2a2a, rgba(234, 142, 160, 0.1));
        }

        .product-track {
            display: flex;
            height: 100%;
            transition: transform 0.5s ease;
        }

        .product-track img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 16px;
            flex-shrink: 0;
            cursor: zoom-in;
        }

        .product-slider {
            touch-action: pan-y;
            user-select: none;
            -webkit-user-select: none;
        }

        .slider-dots-product {
            position: absolute;
            bottom: 8px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 6px;
        }

        .dot-product {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: rgba(0,0,0,0.3);
            border: none;
            cursor: pointer;
            transition: all 0.3s;
        }

        [data-theme="dark"] .dot-product {
            background: rgba(255,255,255,0.3);
        }

        .dot-product.active {
            width: 16px;
            background: var(--coral);
        }

        .product-info {
            margin-top: 16px;
        }

        .product-category {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--coral);
            font-weight: 600;
        }

        .product-name {
            font-size: 24px;
            margin-top: 4px;
            color: var(--text-primary);
        }

        .product-desc {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 8px;
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 16px;
        }

        .product-price {
            font-size: 28px;
            color: var(--coral);
        }

        /* Horizontal Quantity Selector */
        .qty-selector {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(234, 142, 160, 0.1);
            padding: 6px 12px;
            border-radius: 30px;
        }

        .qty-btn {
            width: 32px;
            height: 32px;
            border: none;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 2px 8px rgba(234, 142, 160, 0.3);
        }

        .qty-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 4px 12px rgba(234, 142, 160, 0.4);
        }

        .qty-btn:active {
            transform: scale(0.95);
        }

        .qty-selector span {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
            min-width: 30px;
            text-align: center;
        }

        .add-to-cart {
            width: 100%;
            margin-top: 16px;
            padding: 14px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 0 var(--coral-dark);
            transition: all 0.1s;
        }

        .add-to-cart:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 var(--coral-dark);
        }

        /* Info Section */
        .info-section {
            max-width: 700px;
            margin: 40px auto;
            padding: 24px;
            background: rgba(234, 142, 160, 0.08);
            border: 1px solid rgba(234, 142, 160, 0.2);
            border-radius: 24px;
            opacity: 0;
            transform: translateY(30px);
        }

        [data-theme="dark"] .info-section {
            background: rgba(234, 142, 160, 0.1);
            border-color: rgba(234, 142, 160, 0.3);
        }

        .info-section.visible {
            animation: bloomIn 0.8s ease forwards;
        }

        .info-section h2 {
            font-size: 36px;
            color: var(--coral);
            text-align: center;
            margin-bottom: 20px;
        }

        .info-list {
            list-style: none;
        }

        .info-list li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 10px 0;
            font-size: 14px;
            color: var(--text-secondary);
        }

        .check-icon {
            width: 20px;
            height: 20px;
            background: rgba(234, 142, 160, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .check-icon svg {
            width: 12px;
            height: 12px;
            color: var(--coral);
        }

        /* Instagram Banner */
        .instagram-banner {
            max-width: 600px;
            margin: 40px auto;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(234, 142, 160, 0.2);
            transition: transform 0.4s, box-shadow 0.4s;
            opacity: 0;
            transform: translateY(30px);
        }

        .instagram-banner.visible {
            animation: bloomIn 0.8s ease forwards;
        }

        .instagram-banner:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(234, 142, 160, 0.3);
        }

        .instagram-banner img {
            width: 100%;
            height: auto;
            display: block;
        }

        /* Location Section */
        .location-section {
            max-width: 700px;
            margin: 40px auto;
            padding: 24px;
            background: rgba(234, 142, 160, 0.08);
            border: 1px solid rgba(234, 142, 160, 0.2);
            border-radius: 24px;
            opacity: 0;
            transform: translateY(30px);
        }

        [data-theme="dark"] .location-section {
            background: rgba(234, 142, 160, 0.1);
            border-color: rgba(234, 142, 160, 0.3);
        }

        .location-section.visible {
            animation: bloomIn 0.8s ease forwards;
        }

        .location-section h2 {
            font-size: 36px;
            color: var(--coral);
            text-align: center;
            margin-bottom: 16px;
        }

        .location-text {
            text-align: center;
            font-size: 14px;
            line-height: 1.8;
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .location-text strong {
            display: block;
            margin-top: 8px;
            color: var(--text-primary);
        }

        .map-frame {
            width: 100%;
            height: 280px;
            border: none;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        /* Contact Section */
        .contact-section {
            text-align: center;
            padding: 40px 20px;
            opacity: 0;
            transform: translateY(30px);
        }

        .contact-section.visible {
            animation: bloomIn 0.8s ease forwards;
        }

        .contact-title {
            color: var(--coral);
            font-weight: 700;
            font-size: 18px;
            margin-bottom: 20px;
        }

        .contact-buttons {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
            max-width: 500px;
            margin: 0 auto;
        }

        .contact-btn {
            flex: 1;
            min-width: 120px;
            padding: 14px 20px;
            background: var(--coral);
            color: white;
            text-decoration: none;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 0 var(--coral-dark), 0 8px 16px rgba(0,0,0,0.15);
            transition: all 0.1s;
        }

        .contact-btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 var(--coral-dark);
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 30px 20px;
            border-top: 1px solid var(--border-color);
        }

        .footer p {
            font-size: 14px;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .heart {
            color: var(--coral);
        }

        /* Cart Drawer */
        .cart-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(4px);
            z-index: 2000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.5s;
        }

        .cart-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

        .cart-drawer {
            position: fixed;
            top: 0;
            right: 0;
            width: 100%;
            max-width: 420px;
            height: 100%;
            background: var(--bg-primary);
            z-index: 2001;
            transform: translateX(100%);
            transition: transform 0.5s ease, background 0.5s;
            display: flex;
            flex-direction: column;
        }

        .cart-drawer.open {
            transform: translateX(0);
        }

        .cart-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .cart-header h2 {
            font-size: 28px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-primary);
        }

        .close-cart {
            width: 40px;
            height: 40px;
            border: none;
            background: none;
            cursor: pointer;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
            color: var(--text-primary);
        }

        .close-cart:hover {
            background: rgba(234, 142, 160, 0.2);
        }

        .cart-items {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .cart-empty {
            text-align: center;
            padding: 60px 20px;
        }

        .cart-empty-icon {
            width: 80px;
            height: 80px;
            background: rgba(234, 142, 160, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .cart-empty h3 {
            font-size: 28px;
            margin-bottom: 8px;
            color: var(--text-primary);
        }

        .cart-empty p {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 24px;
        }

        .continue-shopping {
            padding: 14px 28px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border: none;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
        }

        .continue-shopping:hover {
            background: var(--orange-dark);
        }

        .cart-item {
            display: flex;
            gap: 16px;
            background: var(--bg-secondary);
            padding: 16px;
            border-radius: 16px;
            margin-bottom: 12px;
            box-shadow: 0 4px 20px var(--card-shadow);
            border: 1px solid var(--border-color);
        }

        .cart-item-img {
            width: 80px;
            height: 100px;
            border-radius: 12px;
            overflow: hidden;
            background: linear-gradient(to bottom, var(--cream), rgba(245, 213, 213, 0.3));
            flex-shrink: 0;
        }

        [data-theme="dark"] .cart-item-img {
            background: linear-gradient(to bottom, #2a2a2a, rgba(234, 142, 160, 0.1));
        }

        .cart-item-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 8px;
        }

        .cart-item-info {
            flex: 1;
            min-width: 0;
        }

        .cart-item-name {
            font-size: 18px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--text-primary);
        }

        .cart-item-price {
            color: var(--coral);
            font-weight: 600;
            margin-top: 4px;
        }

        .cart-item-actions {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 12px;
        }

        .cart-qty {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cart-qty button {
            width: 28px;
            height: 28px;
            border: none;
            background: rgba(234, 142, 160, 0.2);
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
            color: var(--text-primary);
        }

        .cart-qty button:hover {
            background: var(--blush);
        }

        .remove-item {
            width: 28px;
            height: 28px;
            border: none;
            background: none;
            cursor: pointer;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--rose);
            transition: background 0.3s;
        }

        .remove-item:hover {
            background: rgba(214, 130, 140, 0.1);
        }

        .cart-footer {
            padding: 20px;
            border-top: 1px solid var(--border-color);
            background: var(--bg-secondary);
        }

        .cart-subtotal {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .cart-subtotal span {
            color: var(--text-secondary);
        }

        .cart-subtotal strong {
            font-size: 24px;
            color: var(--text-primary);
        }

        .cart-note {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }

        .checkout-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 0 var(--coral-dark);
            transition: all 0.1s;
        }

        .checkout-btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 var(--coral-dark);
        }

        /* Instagram Modal */
        .instagram-modal {
            position: fixed;
            inset: 0;
            z-index: 3000;
            display: none;
        }

        .instagram-modal.open {
            display: block;
        }

        .instagram-bg {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
        }

        .close-instagram {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 44px;
            height: 44px;
            background: rgba(0,0,0,0.2);
            border: none;
            border-radius: 50%;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
            transition: background 0.3s;
        }

        .close-instagram:hover {
            background: rgba(0,0,0,0.3);
        }

        .instagram-content {
            position: relative;
            height: 100%;
            overflow-y: auto;
            padding: 100px 20px 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .instagram-card {
            max-width: 400px;
            width: 100%;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 24px;
            padding: 32px 24px;
            text-align: center;
        }

        .instagram-card svg {
            width: 48px;
            height: 48px;
            color: white;
            margin-bottom: 16px;
        }

        .instagram-card h2 {
            font-size: 48px;
            color: white;
            margin-bottom: 8px;
        }

        .instagram-card p {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
            margin-bottom: 24px;
        }

        .instagram-link {
            display: block;
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            text-decoration: none;
            border-radius: 16px;
            font-weight: 700;
            margin-bottom: 12px;
            box-shadow: 0 6px 0 var(--orange-dark), 0 10px 20px rgba(0,0,0,0.25);
            transition: all 0.1s;
        }

        .instagram-link:last-of-type {
            margin-bottom: 0;
        }

        .instagram-link:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 var(--orange-dark);
        }

        .instagram-hint {
            color: rgba(255,255,255,0.6);
            font-size: 12px;
            margin-top: 16px;
        }

        /* Image Viewer */
        .image-viewer {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
            z-index: 4000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .image-viewer.open {
            display: flex;
        }

        .close-viewer {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.1);
            border: none;
            border-radius: 50%;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
        }

        .close-viewer:hover {
            background: rgba(255,255,255,0.2);
        }

        .image-viewer img {
            max-width: 100%;
            max-height: 90vh;
            border-radius: 12px;
        }

        /* Animations */
        @keyframes bloomIn {
            from {
                opacity: 0;
                transform: translateY(30px);
                filter: blur(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
                filter: blur(0);
            }
        }


        .collection-toolbar {
            max-width: 1200px;
            margin: 0 auto 20px;
            display: flex;
            gap: 16px;
            align-items: end;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .collection-title {
            font-size: 38px;
            color: var(--coral);
            margin-bottom: 4px;
        }

        .collection-subtitle {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .collection-search {
            min-width: min(100%, 360px);
            flex: 1;
            padding: 14px 16px;
            border: 1px solid rgba(234, 142, 160, 0.25);
            border-radius: 14px;
            background: var(--bg-secondary);
            color: var(--text-primary);
            outline: none;
            box-shadow: 0 6px 18px rgba(0,0,0,0.04);
        }

        .collection-search:focus {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(234, 142, 160, 0.16);
        }

        .product-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-top: 8px;
            flex-wrap: wrap;
        }

        .product-delivery {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .delivery-prompt {
            position: relative;
            margin-bottom: 10px;
            padding: 12px 14px 12px 14px;
            border-radius: 14px;
            background: linear-gradient(135deg, rgba(243, 154, 82, 0.95) 0%, rgba(234, 142, 160, 0.95) 100%);
            color: #fff;
            box-shadow: 0 10px 24px rgba(234, 142, 160, 0.22);
            border: 1px solid rgba(255,255,255,0.28);
            cursor: pointer;
            overflow: hidden;
        }

        .delivery-prompt::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.14), rgba(255,255,255,0));
            pointer-events: none;
        }

        .delivery-prompt-main {
            display: block;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.2px;
            line-height: 1.35;
            padding-right: 28px;
        }

        .delivery-prompt-sub {
            display: block;
            margin-top: 4px;
            font-size: 11px;
            font-weight: 500;
            opacity: 0.95;
            line-height: 1.4;
            padding-right: 28px;
        }

        .delivery-prompt-close {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 24px;
            height: 24px;
            border: none;
            background: rgba(255,255,255,0.18);
            color: #fff;
            border-radius: 999px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            line-height: 1;
            font-weight: 400;
            z-index: 1;
        }

        .delivery-prompt-close:hover {
            background: rgba(255,255,255,0.3);
        }

        .delivery-prompt.is-hidden {
            display: none !important;
        }

        .product-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 16px;
        }

        .product-btn {
            width: 100%;
            padding: 14px 12px;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
            transition: transform 0.1s, box-shadow 0.1s, opacity 0.2s;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            box-shadow: 0 4px 0 var(--coral-dark);
        }

        .product-btn.alt {
            background: transparent;
            color: var(--coral);
            border: 1px solid var(--coral);
            box-shadow: none;
        }

        .product-btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 var(--coral-dark);
        }

        .product-btn.alt:active {
            transform: translateY(4px);
            box-shadow: none;
        }

        /* Customize Button - Official Theme */
        .customize-btn {
            width: 100%;
            margin-top: 12px;
            padding: 14px 12px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 0 var(--coral-dark);
            transition: all 0.1s;
        }

        .customize-btn svg {
            width: 18px;
            height: 18px;
            stroke: white;
            stroke-width: 2;
            fill: none;
        }

        .customize-btn:active {
            transform: translateY(4px);
            box-shadow: 0 2px 0 var(--coral-dark);
        }

        @media (max-width: 768px) {
            .collection-toolbar {
                align-items: stretch;
            }
            .collection-search {
                min-width: 100%;
            }
            .collection-title {
                font-size: 32px;
            }
            .product-actions {
                grid-template-columns: 1fr;
            }
        }

        /* Mobile Menu */
        .mobile-menu-btn {
            display: none;
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }

            .mobile-menu-btn {
                display: flex;
            }

            .hero-title {
                font-size: 52px;
            }

            .hero-subtitle {
                font-size: 28px;
            }

            .products-grid {
                grid-template-columns: 1fr;
            }

            .contact-buttons {
                flex-direction: column;
            }

            .contact-btn {
                width: 100%;
            }
        }

        /* ================= CUSTOMIZATION PAGE STYLES ================= */
        
        /* Customization Page */
        .customization-page {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--bg-primary);
            z-index: 5000;
            overflow-y: auto;
        }

        .customization-page.active {
            display: block;
        }

        .customization-header {
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(234, 142, 160, 0.3);
        }

        .back-arrow {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .back-arrow:hover {
            background: rgba(255,255,255,0.3);
            transform: translateX(-3px);
        }

        .back-arrow svg {
            width: 24px;
            height: 24px;
            stroke: white;
            stroke-width: 2;
            fill: none;
        }

        .customization-header h2 {
            color: white;
            font-size: 28px;
            font-family: 'Great Vibes', cursive;
        }

        .customization-header .header-spacer {
            width: 44px;
        }

        /* Experience Badge */
        .experience-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 20px;
            background: linear-gradient(135deg, rgba(234, 142, 160, 0.1) 0%, rgba(243, 154, 82, 0.1) 100%);
        }

        .experience-badge img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--coral);
            box-shadow: 0 8px 30px rgba(234, 142, 160, 0.3);
        }

        /* Customization Options */
        .customization-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        .customization-option {
            background: var(--bg-secondary);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 20px;
            border: 2px solid var(--border-color);
            box-shadow: 0 4px 20px var(--card-shadow);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .customization-option:hover {
            border-color: var(--coral);
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(234, 142, 160, 0.15);
        }

        .customization-option.selected {
            border-color: var(--coral);
            background: rgba(234, 142, 160, 0.05);
        }

        .option-header {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .option-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .option-icon svg {
            width: 28px;
            height: 28px;
            stroke: white;
            stroke-width: 2;
            fill: none;
        }

        .option-text h3 {
            font-size: 22px;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .option-text p {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .option-arrow {
            margin-left: auto;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(234, 142, 160, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .option-arrow svg {
            width: 16px;
            height: 16px;
            stroke: var(--coral);
            stroke-width: 2;
            fill: none;
        }

        .customization-option:hover .option-arrow {
            background: var(--coral);
        }

        .customization-option:hover .option-arrow svg {
            stroke: white;
        }

        /* Selection Summary */
        .selection-summary {
            background: var(--bg-secondary);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
            border: 2px dashed rgba(234, 142, 160, 0.3);
        }

        .selection-summary h4 {
            font-size: 16px;
            color: var(--coral);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .summary-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: rgba(234, 142, 160, 0.05);
            border-radius: 12px;
            margin-bottom: 8px;
        }

        .summary-item:last-child {
            margin-bottom: 0;
        }

        .summary-item.pattern img {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            object-fit: cover;
        }

        .summary-item.colors {
            flex-wrap: wrap;
        }

        .summary-color-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

        .summary-text {
            font-size: 14px;
            color: var(--text-primary);
        }

        .summary-price {
            margin-left: auto;
            font-size: 14px;
            font-weight: 600;
            color: var(--coral);
        }

        /* Flute Name Input */
        .flute-name-section {
            background: var(--bg-secondary);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
            border: 2px solid var(--border-color);
        }

        .flute-name-section label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 10px;
        }

        .flute-name-section input {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid var(--blush);
            border-radius: 12px;
            font-size: 15px;
            outline: none;
            transition: all 0.3s ease;
            background: var(--bg-primary);
            color: var(--text-primary);
        }

        [data-theme="dark"] .flute-name-section input {
            border-color: rgba(234, 142, 160, 0.3);
        }

        .flute-name-section input:focus {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(234, 142, 160, 0.2);
        }

        /* Download Button */
        .download-customization-btn {
            width: 100%;
            padding: 18px 24px;
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            color: white;
            border: none;
            border-radius: 16px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 6px 0 var(--coral-dark), 0 10px 20px rgba(234, 142, 160, 0.3);
            transition: all 0.1s ease;
            margin-bottom: 20px;
        }

        .download-customization-btn:active {
            transform: translateY(6px);
            box-shadow: 0 2px 0 var(--coral-dark);
        }

        .download-customization-btn svg {
            width: 22px;
            height: 22px;
            stroke: white;
            stroke-width: 2.2;
            fill: none;
        }

        /* Download Complete Prompt */
        .download-complete-prompt {
            position: fixed;
            left: 16px;
            right: 16px;
            bottom: 16px;
            z-index: 10020;
            display: none;
            align-items: center;
            gap: 12px;
            justify-content: space-between;
            padding: 14px 16px;
            background: rgba(255,255,255,0.96);
            border: 1px solid rgba(234, 142, 160, 0.22);
            border-radius: 18px;
            box-shadow: 0 14px 36px rgba(0,0,0,0.16);
            backdrop-filter: blur(10px);
        }

        [data-theme="dark"] .download-complete-prompt {
            background: rgba(30,30,30,0.96);
            border-color: rgba(234, 142, 160, 0.26);
        }

        .download-complete-text {
            font-size: 13px;
            line-height: 1.45;
            color: var(--text-primary);
            flex: 1;
            min-width: 0;
        }

        .download-complete-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .download-complete-whatsapp {
            padding: 12px 16px;
            border: none;
            border-radius: 999px;
            background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
            color: white;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 0 #075E54;
        }

        .download-complete-whatsapp:active {
            transform: translateY(3px);
            box-shadow: 0 2px 0 #075E54;
        }

        .download-complete-close {
            width: 34px;
            height: 34px;
            border: none;
            border-radius: 50%;
            background: rgba(234, 142, 160, 0.1);
            color: var(--text-primary);
            cursor: pointer;
            font-size: 18px;
            line-height: 1;
        }

        /* ================= PATTERN PAGE STYLES ================= */
        
        .pattern-page, .color-page {
            display: none;
            position: fixed;
            inset: 0;
            background: var(--bg-primary);
            z-index: 6000;
            overflow-y: auto;
        }

        .pattern-page.active, .color-page.active {
            display: block;
        }

        .page-header {
            background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(234, 142, 160, 0.3);
        }

        .page-header h2 {
            color: white;
            font-size: 24px;
            font-family: 'Great Vibes', cursive;
        }

        .page-content {
            max-width: 600px;
            margin: 0 auto;
            padding: 24px 20px;
        }

        /* Pattern Types */
        .pattern-types {
            margin-bottom: 24px;
        }

        .pattern-types h3 {
            font-size: 18px;
            color: var(--text-primary);
            margin-bottom: 16px;
        }

        .pattern-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .pattern-type-card {
            background: var(--bg-secondary);
            border-radius: 16px;
            padding: 16px;
            border: 2px solid var(--border-color);
